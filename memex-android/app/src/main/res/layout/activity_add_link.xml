<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:background="#0A0A0A">
    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:hint="Title *">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/editTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
    </com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:hint="URL *">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/editUrl" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" android:textColor="#FFFFFF"/>
    </com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:hint="Category">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/editCategory" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="General" android:textColor="#FFFFFF"/>
    </com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:hint="Tags (comma-separated)">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/editTags" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
    </com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.button.MaterialButton android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Save Link" android:backgroundTint="#FF7A29" android:textColor="#000000"/>
</LinearLayout>
