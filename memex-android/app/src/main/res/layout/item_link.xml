<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="14dp"
    android:layout_marginBottom="6dp" android:layout_marginHorizontal="8dp"
    android:background="@drawable/card_bg" android:gravity="center_vertical">
    <TextView android:id="@+id/linkIcon" android:layout_width="32dp" android:layout_height="32dp"
        android:textSize="20sp" android:gravity="center"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:id="@+id/linkTitle" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFA35C" android:textSize="16sp" android:fontFamily="cursive"/>
        <TextView android:id="@+id/linkCategory" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp"/>
        <TextView android:id="@+id/linkUrl" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#555555" android:textSize="10sp" android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
