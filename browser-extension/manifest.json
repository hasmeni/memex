{
  "manifest_version": 3,
  "name": "Memex Link Saver",
  "version": "1.0.0",
  "description": "Save the current page to your Memex instance with one click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "link-saver@ironylabs.studio",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
